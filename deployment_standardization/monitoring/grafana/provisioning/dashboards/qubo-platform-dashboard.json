{
  "dashboard": {
    "id": null,
    "title": "QURVE AI Platform Dashboard",
    "tags": ["qubo", "platform", "production"],
    "style": "dark",
    "timezone": "browser",
    "refresh": "30s",
    "schemaVersion": 38,
    "version": 1,
    "panels": [
      {
        "id": 1,
        "title": "System Overview",
        "type": "stat",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        },
        "targets": [
          {
            "expr": "up{job=~\"qubo-.*\"}",
            "legendFormat": "{{ job }}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "options": {
                  "0": {
                    "color": "red",
                    "index": 0,
                    "text": "DOWN"
                  },
                  "1": {
                    "color": "green",
                    "index": 1,
                    "text": "UP"
                  }
                },
                "type": "value"
              }
            ]
          }
        },
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "justifyMode": "center",
          "orientation": "horizontal",
          "reduceOptions": {
            "values": false,
            "calcs": [
              "lastNotNull"
            ],
            "fields": ""
          },
          "textMode": "auto"
        }
      },
      {
        "id": 2,
        "title": "Request Rate",
        "type": "graph",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        },
        "targets": [
          {
            "expr": "rate(http_requests_total{job=~\"qubo-.*\"}[5m])",
            "legendFormat": "{{ job }}",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "Requests/sec"
          }
        ],
        "xAxis": {
          "mode": "time"
        }
      },
      {
        "id": 3,
        "title": "Response Time",
        "type": "graph",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=~\"qubo-.*\"}[5m]))",
            "legendFormat": "95th percentile - {{ job }}",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=~\"qubo-.*\"}[5m]))",
            "legendFormat": "50th percentile - {{ job }}",
            "refId": "B"
          }
        ],
        "yAxes": [
          {
            "label": "Seconds"
          }
        ],
        "xAxis": {
          "mode": "time"
        }
      },
      {
        "id": 4,
        "title": "Error Rate",
        "type": "graph",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        },
        "targets": [
          {
            "expr": "rate(http_requests_total{job=~\"qubo-.*\",status=~\"5..\"}[5m]) / rate(http_requests_total{job=~\"qubo-.*\"}[5m])",
            "legendFormat": "{{ job }}",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "Error Rate",
            "max": 1,
            "min": 0,
            "unit": "percentunit"
          }
        ],
        "xAxis": {
          "mode": "time"
        }
      },
      {
        "id": 5,
        "title": "Benchmark Executions",
        "type": "stat",
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 0,
          "y": 16
        },
        "targets": [
          {
            "expr": "increase(qubo_benchmark_executions_total[1h])",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "min": 0
          }
        }
      },
      {
        "id": 6,
        "title": "Success Rate",
        "type": "stat",
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 6,
          "y": 16
        },
        "targets": [
          {
            "expr": "rate(qubo_benchmark_executions_success_total[1h]) / rate(qubo_benchmark_executions_total[1h])",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "max": 1,
            "min": 0,
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 0.8
                },
                {
                  "color": "green",
                  "value": 0.95
                }
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "QPU Executions",
        "type": "stat",
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 12,
          "y": 16
        },
        "targets": [
          {
            "expr": "increase(qubo_qpu_executions_total[1h])",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "min": 0
          }
        }
      },
      {
        "id": 8,
        "title": "Cloud Executions",
        "type": "stat",
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 18,
          "y": 16
        },
        "targets": [
          {
            "expr": "increase(qubo_cloud_executions_total[1h])",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "min": 0
          }
        }
      },
      {
        "id": 9,
        "title": "User Activity",
        "type": "graph",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 24
        },
        "targets": [
          {
            "expr": "rate(qubo_user_sessions_created_total[5m])",
            "legendFormat": "Session Creation Rate",
            "refId": "A"
          },
          {
            "expr": "rate(qubo_user_api_requests_total[5m])",
            "legendFormat": "API Request Rate",
            "refId": "B"
          }
        ],
        "yAxes": [
          {
            "label": "Rate"
          }
        ],
        "xAxis": {
          "mode": "time"
        }
      },
      {
        "id": 10,
        "title": "Quota Utilization",
        "type": "graph",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 24
        },
        "targets": [
          {
            "expr": "qubo_user_quota_utilization_ratio",
            "legendFormat": "{{ user_id }}",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "Utilization",
            "max": 1,
            "min": 0,
            "unit": "percentunit"
          }
        ],
        "xAxis": {
          "mode": "time"
        }
      },
      {
        "id": 11,
        "title": "System Resources",
        "type": "graph",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 32
        },
        "targets": [
          {
            "expr": "100 - (avg by (instance) (irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
            "legendFormat": "CPU Usage - {{ instance }}",
            "refId": "A"
          },
          {
            "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
            "legendFormat": "Memory Usage - {{ instance }}",
            "refId": "B"
          }
        ],
        "yAxes": [
          {
            "label": "Percent",
            "max": 100,
            "min": 0,
            "unit": "percent"
          }
        ],
        "xAxis": {
          "mode": "time"
        }
      },
      {
        "id": 12,
        "title": "Database Connections",
        "type": "graph",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 32
        },
        "targets": [
          {
            "expr": "pg_stat_database_numbackends",
            "legendFormat": "Active Connections",
            "refId": "A"
          },
          {
            "expr": "pg_settings_max_connections",
            "legendFormat": "Max Connections",
            "refId": "B"
          }
        ],
        "yAxes": [
          {
            "label": "Connections"
          }
        ],
        "xAxis": {
          "mode": "time"
        }
      },
      {
        "id": 13,
        "title": "Replay System Activity",
        "type": "graph",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 40
        },
        "targets": [
          {
            "expr": "rate(qubo_replay_requests_total[5m])",
            "legendFormat": "Replay Request Rate",
            "refId": "A"
          },
          {
            "expr": "rate(qubo_replay_requests_failed_total[5m])",
            "legendFormat": "Replay Failure Rate",
            "refId": "B"
          }
        ],
        "yAxes": [
          {
            "label": "Rate"
          }
        ],
        "xAxis": {
          "mode": "time"
        }
      },
      {
        "id": 14,
        "title": "Governance Violations",
        "type": "stat",
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 12,
          "y": 40
        },
        "targets": [
          {
            "expr": "increase(qubo_governance_violations_total[1h])",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "min": 0,
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 1
                },
                {
                  "color": "red",
                  "value": 5
                }
              ]
            }
          }
        }
      },
      {
        "id": 15,
        "title": "Security Events",
        "type": "stat",
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 18,
          "y": 40
        },
        "targets": [
          {
            "expr": "increase(qubo_security_events_total[1h])",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "min": 0,
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 1
                },
                {
                  "color": "red",
                  "value": 3
                }
              ]
            }
          }
        }
      },
      {
        "id": 16,
        "title": "Execution Queue Length",
        "type": "graph",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 48
        },
        "targets": [
          {
            "expr": "qubo_execution_queue_length",
            "legendFormat": "Queue Length",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "Jobs",
            "min": 0
          }
        ],
        "xAxis": {
          "mode": "time"
        }
      },
      {
        "id": 17,
        "title": "Cache Performance",
        "type": "graph",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 48
        },
        "targets": [
          {
            "expr": "rate(redis_commands_total[5m])",
            "legendFormat": "Commands/sec",
            "refId": "A"
          },
          {
            "expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m]))",
            "legendFormat": "Hit Rate",
            "refId": "B"
          }
        ],
        "yAxes": [
          {
            "label": "Rate"
          }
        ],
        "xAxis": {
          "mode": "time"
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "templating": {
      "list": []
    }
  }
}
