# =============================================================================
# Qurve Project - Strict .gitignore
# SECURITY: No secrets, credentials, or environment-specific files allowed
# =============================================================================

# ── CRITICAL SECURITY: Never commit secrets ──────────────────────────────────
.env
.env.*
!.env.example
*.env
apikey.json
*.key
*.pem
*.p12
*.pfx
secrets/
credentials/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
/lib/
/lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Virtual Environments ─────────────────────────────────────────────────────
.venv/
.venv*/
venv/
venv*/
ENV/
env/
env.bak/
quantum_env/

# ── Python Tooling ───────────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover

