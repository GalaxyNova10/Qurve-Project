# QURVE AI - Environment Configuration Template
# Copy this file to .env and fill in your actual values
# DO NOT commit the real .env file to version control

# AWS Credentials
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY
AWS_SESSION_TOKEN=YOUR_SESSION_TOKEN

# AWS Configuration
AWS_DEFAULT_REGION=us-east-1
AWS_REGION=us-east-1

# QURVE Platform Configuration
QUBO_ENVIRONMENT=production
QUBO_LOG_LEVEL=INFO
QUBO_DEBUG=false

# Database Configuration
DATABASE_URL=postgresql://qubo_user:password@localhost:5432/qubo_platform
REDIS_URL=redis://:password@localhost:6379/0

# Braket Configuration
BRAKET_REGION=us-east-1
BRAKET_S3_BUCKET=qubo-braket-results

# Monitoring Configuration
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001

# Security Configuration
JWT_SECRET=YOUR_JWT_SECRET
ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY

# Rate Limiting Configuration
RATE_LIMIT_REDIS_URL=redis://:password@localhost:6379/1

# Telemetry Configuration
TELEMETRY_ENABLED=true
TELEMETRY_RETENTION_DAYS=30

# Governance Configuration
GOVERNANCE_ENABLED=true
AUDIT_TRAIL_ENABLED=true
REPLAY_ENABLED=true
